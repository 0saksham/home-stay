# ─────────────────────────────────────────────
# The Nest Stay — Server Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
PORT=5000
JWT_SECRET=change_this_to_a_long_random_secret_string

# ── Development Mode ─────────────────────────
# Set to true  → OTP is logged to console only (no SMS sent)
# Set to false → Real SMS sent via Fast2SMS
DEV_MODE=true

# ── Fast2SMS (SMS OTP) ────────────────────────
# Sign up at https://fast2sms.com → Dev API → copy your key
# Free ₹50 test credits on signup
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# ── Email (Nodemailer / Gmail SMTP) ──────────
# Used to send booking confirmation emails to admin
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password   # Use an App Password, not your real password
ADMIN_EMAIL=admin@yourdomain.com
